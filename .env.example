# ════════════════════════════════════════════════════════════════
# DATABASE — Vercel Postgres (auto-popolate da Vercel)
# ════════════════════════════════════════════════════════════════
# Queste variabili vengono create automaticamente da Vercel
# quando colleghi un database Postgres al progetto.
# Per sviluppo locale, copia i valori da: Vercel Dashboard → Storage → .env.local
POSTGRES_PRISMA_URL="postgresql://user:password@host:5432/fapetroli?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLED="postgresql://user:password@host:5432/fapetroli?sslmode=require"

# ════════════════════════════════════════════════════════════════
# AUTENTICAZIONE
# ════════════════════════════════════════════════════════════════
# Genera con: openssl rand -base64 32
AUTH_SECRET="cambia-questa-stringa-con-una-chiave-random-lunga"

# ════════════════════════════════════════════════════════════════
# CREDENZIALI ADMIN (usate dal seed script)
# ════════════════════════════════════════════════════════════════
ADMIN_EMAIL="admin@fapetroli.it"
ADMIN_PASSWORD="CambiaQuestaPasswordSubito2025!"
ADMIN_NAME="Amministratore FA Petroli"
